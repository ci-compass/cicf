# DigitalOcean Spaces (S3) Credentials
# Obtain these from the DigitalOcean Control Panel (API -> Spaces Keys)
# NEVER COMMIT YOUR ACTUAL .env FILE TO GITHUB

DO_SPACES_KEY='YOUR_ACCESS_KEY_HERE'
DO_SPACES_SECRET='YOUR_SECRET_KEY_HERE'

# The bucket containing the source data (e.g., LIGO HDF5 files)
DO_SPACES_BUCKET='cicf-2026'

# The bucket where you will upload your Map-Reduce results
# Replace 'YOURNAME' with your actual name to avoid collisions
DO_SPACES_RESULT_BUCKET='cicf-results-YOURNAME'

# Optional: OpenAlex email for the "polite pool"
# OPENALEX_EMAIL='your-email@example.edu'
